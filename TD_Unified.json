{
  "@context": [
    "https://www.w3.org/2022/wot/td/v1.1",
    {
      "healthiot": "https://w3id.org/iotschema/health#",
      "saref": "https://saref.etsi.org/core/",
      "om": "http://www.ontology-of-units-of-measure.org/resource/om-2/"
    }
  ],
  "@type": [
    "Thing",
    "healthiot:WearableHealthMonitor",
    "healthiot:HeartRateSensor",
    "healthiot:PulseOximeter",
    "healthiot:BodyTemperatureSensor",
    "saref:Actuator"
  ],
  "id": "urn:dev:wot:health-monitor:wearable:patient001",
  "title": "Dispositivo Vestível de Monitorização de Saúde (ESP32)",
  "titles": {
    "pt": "Dispositivo Vestível de Monitorização de Saúde (ESP32)",
    "en": "Wearable Health Monitoring Device (ESP32)"
  },
  "description": "Thing única que agrega num só dispositivo vestível ESP32 os sensores MAX30100 (frequência cardíaca + SpO2) e MLX90614 (temperatura corporal IR) e um atuador de vibração háptico. Exposta pelo gateway Raspberry Pi através do runtime Eclipse Thingweb (node-wot), cumprindo os Requisitos 1, 2, 3, 4, 6, 7, 8, 10, 11 e 12 do enunciado do Grupo PG_03.",
  "version": {"instance": "1.0.0", "model": "1.0.0"},
  "created": "2026-04-16T00:00:00Z",
  "modified": "2026-04-16T00:00:00Z",
  "support": "https://github.com/estig-beja/wot-health-monitor/issues",

  "base": "http://localhost:8080/",

  "securityDefinitions": {
    "nosec_sc": {
      "scheme": "nosec",
      "description": "Apenas em rede interna confiável, entre ESP32 e Mosquitto com TLS-PSK."
    },
    "psk_sc": {
      "scheme": "psk",
      "description": "Chave pré-partilhada ESP32↔Mosquitto sobre MQTT+TLS 1.2."
    },
    "bearer_sc": {
      "scheme": "bearer",
      "format": "jwt",
      "alg": "HS256",
      "in": "header",
      "name": "Authorization",
      "authorization": "https://gateway.wot-health.local/api/token/",
      "description": "JWT emitido por djangorestframework-simplejwt (exp=1h + refresh token). Roles RBAC: patient, caregiver, physician, admin (RNF-05/06)."
    }
  },
  "security": ["nosec_sc"],

  "properties": {
    "heartRate": {
      "@type": "healthiot:HeartRate",
      "title": "Frequência Cardíaca",
      "description": "Batimentos por minuto medidos pelo MAX30100 via fotopletismografia (PPG).",
      "type": "integer",
      "unit": "om:beats-per-minute",
      "minimum": 30,
      "maximum": 220,
      "readOnly": true,
      "observable": true,
      "forms": [
        {
          "href": "http://localhost:8080/things/patient001/properties/heartRate",
          "op": ["readproperty"],
          "contentType": "application/json",
          "htv:methodName": "GET"
        },
        {
          "href": "mqtt://localhost:1883/health/patient001/heartrate",
          "op": ["observeproperty", "unobserveproperty"],
          "contentType": "application/json",
          "mqv:controlPacket": "subscribe",
          "mqv:qos": 1,
          "mqv:retain": false
        }
      ]
    },

    "spO2": {
      "@type": "healthiot:OxygenSaturation",
      "title": "Saturação de Oxigénio (SpO2)",
      "description": "Percentagem de hemoglobina oxigenada medida pelo MAX30100.",
      "type": "number",
      "unit": "om:percent",
      "minimum": 0,
      "maximum": 100,
      "readOnly": true,
      "observable": true,
      "forms": [
        {
          "href": "http://localhost:8080/things/patient001/properties/spO2",
          "op": ["readproperty"],
          "contentType": "application/json",
          "htv:methodName": "GET"
        },
        {
          "href": "mqtt://localhost:1883/health/patient001/spo2",
          "op": ["observeproperty", "unobserveproperty"],
          "contentType": "application/json",
          "mqv:qos": 1
        }
      ]
    },

    "bodyTemperature": {
      "@type": "healthiot:BodyTemperature",
      "title": "Temperatura Corporal",
      "description": "Temperatura da pele em °C, medida pelo MLX90614 (IR, ±0.5 °C).",
      "type": "number",
      "unit": "om:degree-Celsius",
      "minimum": 20.0,
      "maximum": 45.0,
      "readOnly": true,
      "observable": true,
      "forms": [
        {
          "href": "http://localhost:8080/things/patient001/properties/bodyTemperature",
          "op": ["readproperty"],
          "contentType": "application/json",
          "htv:methodName": "GET"
        },
        {
          "href": "mqtt://localhost:1883/health/patient001/temperature",
          "op": ["observeproperty"],
          "contentType": "application/json",
          "mqv:qos": 1
        }
      ]
    },

    "ambientTemperature": {
      "title": "Temperatura Ambiente",
      "description": "Temperatura do ambiente reportada pelo MLX90614 (para compensação térmica).",
      "type": "number",
      "unit": "om:degree-Celsius",
      "readOnly": true,
      "observable": false,
      "forms": [
        {
          "href": "http://localhost:8080/things/patient001/properties/ambientTemperature",
          "op": ["readproperty"],
          "contentType": "application/json"
        }
      ]
    },

    "samplingIntervalMs": {
      "title": "Intervalo de amostragem (ms)",
      "description": "Intervalo comum entre leituras dos sensores. Padrão: 5000 ms (conforme secção 3.1).",
      "type": "integer",
      "unit": "om:millisecond",
      "minimum": 1000,
      "maximum": 60000,
      "default": 5000,
      "readOnly": false,
      "observable": false,
      "forms": [
        {
          "href": "http://localhost:8080/things/patient001/properties/samplingIntervalMs",
          "op": ["readproperty", "writeproperty"],
          "contentType": "application/json"
        }
      ]
    },

    "emissivity": {
      "title": "Emissividade (MLX90614)",
      "description": "Coeficiente de emissividade (pele humana ≈ 0.98).",
      "type": "number",
      "minimum": 0.1,
      "maximum": 1.0,
      "default": 0.98,
      "readOnly": false,
      "observable": false,
      "forms": [
        {
          "href": "http://localhost:8080/things/patient001/properties/emissivity",
          "op": ["readproperty", "writeproperty"],
          "contentType": "application/json"
        }
      ]
    },

    "thresholds": {
      "title": "Limiares Clínicos Personalizados",
      "description": "Limiares individuais de BPM, SpO2 e temperatura usados na geração de alertas (UC-05, RF-14).",
      "type": "object",
      "readOnly": false,
      "observable": true,
      "properties": {
        "heartRate": {
          "type": "object",
          "properties": {
            "min": {"type": "integer", "minimum": 30, "maximum": 100, "default": 50},
            "max": {"type": "integer", "minimum": 100, "maximum": 220, "default": 150}
          }
        },
        "spO2": {
          "type": "object",
          "properties": {
            "min": {"type": "number", "minimum": 80, "maximum": 100, "default": 90}
          }
        },
        "bodyTemperature": {
          "type": "object",
          "properties": {
            "min": {"type": "number", "default": 35.0},
            "max": {"type": "number", "default": 38.0}
          }
        }
      },
      "forms": [
        {
          "href": "http://localhost:8080/things/patient001/properties/thresholds",
          "op": ["readproperty", "writeproperty"],
          "contentType": "application/json"
        },
        {
          "href": "mqtt://localhost:1883/health/patient001/thresholds",
          "op": ["observeproperty"],
          "contentType": "application/json",
          "mqv:qos": 1,
          "mqv:retain": true
        }
      ]
    },

    "vibrationActive": {
      "title": "Vibração activa",
      "description": "Indica se o motor de vibração está actualmente em funcionamento.",
      "type": "boolean",
      "readOnly": true,
      "observable": true,
      "forms": [
        {
          "href": "http://localhost:8080/things/patient001/properties/vibrationActive",
          "op": ["readproperty"],
          "contentType": "application/json"
        },
        {
          "href": "mqtt://localhost:1883/health/patient001/vibration/state",
          "op": ["observeproperty"],
          "contentType": "application/json",
          "mqv:qos": 1,
          "mqv:retain": true
        }
      ]
    },

    "lastVibrationAt": {
      "title": "Última activação do atuador",
      "type": "string",
      "format": "date-time",
      "readOnly": true,
      "forms": [
        {
          "href": "http://localhost:8080/things/patient001/properties/lastVibrationAt",
          "op": ["readproperty"],
          "contentType": "application/json"
        }
      ]
    },

    "connectionStatus": {
      "title": "Estado de Conectividade",
      "type": "string",
      "enum": ["online", "offline", "reconnecting"],
      "readOnly": true,
      "observable": true,
      "forms": [
        {
          "href": "http://localhost:8080/things/patient001/properties/connectionStatus",
          "op": ["readproperty"],
          "contentType": "application/json"
        },
        {
          "href": "mqtt://localhost:1883/health/patient001/wearable/status",
          "op": ["observeproperty"],
          "contentType": "application/json",
          "mqv:qos": 1,
          "mqv:retain": true
        }
      ]
    },

    "batteryLevel": {
      "title": "Nível de Bateria (%)",
      "type": "integer",
      "unit": "om:percent",
      "minimum": 0,
      "maximum": 100,
      "readOnly": true,
      "observable": true,
      "forms": [
        {
          "href": "http://localhost:8080/things/patient001/properties/batteryLevel",
          "op": ["readproperty"],
          "contentType": "application/json"
        }
      ]
    },

    "patient": {
      "title": "Paciente associado",
      "description": "Dados mínimos de identificação do paciente emparelhado com o dispositivo.",
      "type": "object",
      "readOnly": true,
      "properties": {
        "patientId": {"type": "string"},
        "displayName": {"type": "string"},
        "age": {"type": "integer"}
      },
      "forms": [
        {
          "href": "http://localhost:8080/things/patient001/properties/patient",
          "op": ["readproperty"],
          "contentType": "application/json"
        }
      ]
    }
  },

  "actions": {
    "calibrate": {
      "title": "Calibrar sensores",
      "description": "Executa a rotina de calibração automática do MAX30100 (LED current, sample averaging).",
      "idempotent": false,
      "safe": false,
      "synchronous": false,
      "input": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["quick", "full"],
            "default": "quick"
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "durationMs": {"type": "integer"}
        }
      },
      "forms": [
        {
          "href": "api/things/wearable/patient001/actions/calibrate",
          "op": ["invokeaction"],
          "contentType": "application/json",
          "htv:methodName": "POST"
        }
      ]
    },

    "activateVibration": {
      "@type": "healthiot:HapticAlert",
      "title": "Activar vibração",
      "description": "Activa o motor de vibração com duração, padrão e intensidade configuráveis (RF-08, RNF-02 <500ms).",
      "idempotent": false,
      "safe": false,
      "synchronous": true,
      "input": {
        "type": "object",
        "required": ["duration_ms", "pattern"],
        "properties": {
          "duration_ms": {
            "type": "integer",
            "minimum": 100,
            "maximum": 10000
          },
          "pattern": {
            "type": "string",
            "enum": ["short", "long", "sos"],
            "default": "short"
          },
          "intensity": {
            "type": "integer",
            "minimum": 0,
            "maximum": 255,
            "default": 200
          }
        }
      },
      "output": {
        "type": "object",
        "properties": {
          "success": {"type": "boolean"},
          "startedAt": {"type": "string", "format": "date-time"}
        }
      },
      "forms": [
        {
          "href": "api/things/wearable/patient001/actions/activateVibration",
          "op": ["invokeaction"],
          "contentType": "application/json",
          "htv:methodName": "POST"
        },
        {
          "href": "mqtt://localhost:1883/health/patient001/vibration/cmd",
          "op": ["invokeaction"],
          "contentType": "application/json",
          "mqv:controlPacket": "publish",
          "mqv:qos": 2
        }
      ]
    },

    "stopVibration": {
      "title": "Parar vibração",
      "description": "Interrompe imediatamente qualquer vibração em curso.",
      "idempotent": true,
      "safe": true,
      "forms": [
        {
          "href": "api/things/wearable/patient001/actions/stopVibration",
          "op": ["invokeaction"],
          "contentType": "application/json",
          "htv:methodName": "POST"
        }
      ]
    },

    "registerDevice": {
      "title": "Registar no Thing Directory",
      "description": "Publica esta Thing Description no Thing Directory Eclipse Thingweb (RF-11/RF-12, Req. 11).",
      "idempotent": true,
      "safe": false,
      "input": {
        "type": "object",
        "properties": {
          "directoryUrl": {
            "type": "string",
            "format": "uri",
            "default": "https://gateway.wot-health.local:8081/things"
          }
        }
      },
      "forms": [
        {
          "href": "api/things/wearable/patient001/actions/registerDevice",
          "op": ["invokeaction"],
          "contentType": "application/json",
          "htv:methodName": "POST"
        }
      ]
    }
  },

  "events": {
    "criticalHealthAlert": {
      "@type": "healthiot:CriticalHealthAlert",
      "title": "Alerta Clínico",
      "description": "Emitido quando qualquer sensor dispara uma violação de limiar. Severidade classificada como green/yellow/red conforme escala definida no UC-02 (RF-08, RNF-02 <500ms).",
      "data": {
        "type": "object",
        "required": ["source", "value", "severity", "timestamp"],
        "properties": {
          "source": {
            "type": "string",
            "enum": ["heartRate", "spO2", "bodyTemperature"]
          },
          "value": {"type": "number"},
          "threshold": {
            "type": "object",
            "properties": {
              "min": {"type": "number"},
              "max": {"type": "number"}
            }
          },
          "severity": {
            "type": "string",
            "enum": ["green", "yellow", "red"]
          },
          "patientId": {"type": "string"},
          "timestamp": {"type": "string", "format": "date-time"}
        }
      },
      "forms": [
        {
          "href": "mqtt://localhost:1883/health/patient001/alerts",
          "op": ["subscribeevent", "unsubscribeevent"],
          "contentType": "application/json",
          "mqv:qos": 2,
          "mqv:retain": false
        },
        {
          "href": "api/things/wearable/patient001/events/criticalHealthAlert",
          "op": ["subscribeevent"],
          "subprotocol": "sse",
          "contentType": "text/event-stream"
        }
      ]
    },

    "vibrationCompleted": {
      "title": "Vibração concluída",
      "description": "Emitido quando um ciclo de vibração termina.",
      "data": {
        "type": "object",
        "properties": {
          "durationMs": {"type": "integer"},
          "pattern": {"type": "string"},
          "timestamp": {"type": "string", "format": "date-time"}
        }
      },
      "forms": [
        {
          "href": "mqtt://localhost:1883/health/patient001/vibration/events",
          "op": ["subscribeevent"],
          "contentType": "application/json",
          "mqv:qos": 1
        }
      ]
    },

    "deviceStatusChanged": {
      "title": "Mudança de estado do dispositivo",
      "description": "Emitido quando o dispositivo passa a online/offline ou a bateria atinge um nível crítico.",
      "data": {
        "type": "object",
        "properties": {
          "connectionStatus": {"type": "string", "enum": ["online", "offline", "reconnecting"]},
          "batteryLevel": {"type": "integer"},
          "timestamp": {"type": "string", "format": "date-time"}
        }
      },
      "forms": [
        {
          "href": "mqtt://localhost:1883/health/patient001/wearable/events",
          "op": ["subscribeevent"],
          "contentType": "application/json",
          "mqv:qos": 1
        }
      ]
    }
  },

  "links": [
    {
      "rel": "type",
      "href": "https://www.w3.org/TR/wot-thing-description11/"
    },
    {
      "rel": "service-doc",
      "href": "https://gateway.wot-health.local/docs/",
      "type": "text/html"
    },
    {
      "rel": "alternate",
      "href": "coap://gateway.wot-health.local/things/wearable/patient001",
      "type": "application/td+json"
    }
  ],

  "profile": [
    "https://www.w3.org/2022/wot/profile/http",
    "https://www.w3.org/2022/wot/profile/mqtt"
  ]
}
